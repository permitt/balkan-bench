{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://balkanbench.com/schemas/task_throughput.json",
  "title": "BalkanBench Per-Task Throughput Measurement",
  "type": "object",
  "required": [
    "benchmark",
    "language",
    "task",
    "model",
    "model_id",
    "hardware",
    "precision",
    "batch_size",
    "max_seq_len",
    "warmup_batches",
    "measurement_batches",
    "throughput_ex_per_sec",
    "throughput_tok_per_sec",
    "peak_vram_mib",
    "torch_version",
    "driver_version",
    "measured_at",
    "sponsor"
  ],
  "additionalProperties": false,
  "properties": {
    "benchmark":              { "type": "string", "minLength": 1 },
    "language":               { "type": "string", "minLength": 1 },
    "task":                   { "type": "string", "minLength": 1 },
    "model":                  { "type": "string", "minLength": 1 },
    "model_id":               { "type": "string", "minLength": 1 },
    "hardware":               { "type": "string", "minLength": 1 },
    "precision":              { "type": "string", "enum": ["fp16", "bf16", "fp32"] },
    "batch_size":             { "type": "integer", "minimum": 1 },
    "max_seq_len":            { "type": "integer", "minimum": 1 },
    "warmup_batches":         { "type": "integer", "minimum": 0 },
    "measurement_batches":    { "type": "integer", "minimum": 1 },
    "throughput_ex_per_sec":  { "type": "number", "exclusiveMinimum": 0 },
    "throughput_tok_per_sec": { "type": "number", "exclusiveMinimum": 0 },
    "peak_vram_mib":          { "type": "number", "minimum": 0 },
    "torch_version":          { "type": "string", "minLength": 1 },
    "driver_version":         { "type": "string", "minLength": 1 },
    "image_digest":           { "type": "string" },
    "measured_at":            { "type": "string", "format": "date-time" },
    "sponsor":                { "type": "string", "minLength": 1 }
  }
}
